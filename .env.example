# SCREENER configuration — copy to `.env` and adjust, or leave unset to use defaults.
# Defaults point at the freqvwap project on the original host.

# Access token required by every endpoint (also the API key for scripts).
DATA_SERVER_TOKEN=change-me

# Login credentials for the /login page and HTTP Basic auth.
# Username defaults to "admin"; password falls back to DATA_SERVER_TOKEN if unset.
# SCREENER_USER=admin
# SCREENER_PASSWORD=change-me-too
# Secret used to sign the session cookie (defaults to a value derived from the token).
# SCREENER_SECRET_KEY=
# Session lifetime in seconds (default 604800 = 7 days).
# SCREENER_SESSION_MAX_AGE=604800

# Where the market data / pairlist / token live. Override to run elsewhere.
# SCREENER_PROJECT_ROOT=/home/titus/freqvwap
# SCREENER_DATA_DIR=/path/to/user_data/data/futures
# SCREENER_PAIRS_FILE=/path/to/user_data/pairs.json
# SCREENER_ENV_FILE=/path/to/.env

# Optional: explicit python venv for the shell scripts (else a local ./.venv is preferred).
# SCREENER_VENV=/path/to/.venv
# Hostname shown in menu URLs.
# SCREENER_HOST=permanent

# Momentum screener (build_momentum.py): scrapes CoinMarketCap trending, scores 1h/2h/4h.
# By default it uses CMC's free public data-API (no key). To use the official Pro API
# instead, set a key here. All weights/thresholds live in config.json ("momentum").
# SCREENER_CMC_API_KEY=

# Telegram alerts (notify_telegram.py): ping you when a coin newly enters the
# LONG or SHORT list above the score threshold. Leave unset to disable.
#   1. Create a bot with @BotFather -> copy the token below.
#   2. Message your bot once, then get your chat id (e.g. from @userinfobot).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID can be a personal chat id and/or a group id (negative,
# e.g. -1001234567890). List several, comma- or space-separated, to alert
# multiple recipients. For a group: add the bot to the group, post a message,
# then read the id from getUpdates.
# TELEGRAM_CHAT_ID=
# Score thresholds for an alert. Shorts score higher than longs, so they are
# tuned separately; ALERT_MIN_SCORE is the shared fallback.
# ALERT_MIN_SCORE=1.9
# ALERT_MIN_SCORE_LONG=1.3     # longs rarely exceed ~1.6, so this is lower
# ALERT_MIN_SCORE_SHORT=1.9
