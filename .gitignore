# Runtime / secrets (screener.log contains tokenized request URLs)
screener.log
screener.pid
__pycache__/
*.pyc

# Local machine config (token + host-specific paths)
.env

# Bundled sample data is force-added; further downloads here are ignored
data/futures/*

# Local virtualenv
.venv/

# Agent worktrees / local tooling
.claude/

# Stray local files
*.deb*
*.bak*
stats_backup_*/
eval_results.json.bak*

# Momentum/shorts output is regenerated by cron every 5 min — keep it out of git (avoids churn)
momentum_ranking.json
shorts_ranking.json
eval_results.json
# Pick history (entry prices logged each run for later evaluation)
momentum_history/
shorts_history/
# Cron refresh log
momentum_refresh.log

# Telegram alert dedup state
.alert_state.json

# Cron single-instance lock
.refresh.lock
# Eval single-instance lock
.eval.lock
# Static universe cache
.cache/
